# =============================================================================
# Repeater Monitor — Environment Variables Template
# =============================================================================
# Скопируйте этот файл в .env и заполните реальными значениями:
#   cp .env.example .env
#
# ВАЖНО: Файл .env добавлен в .gitignore и НЕ коммитится в Git!
# =============================================================================

# -----------------------------------------------------------------------------
# Cisco 3845 SSH credentials (для DHCP Collector)
# -----------------------------------------------------------------------------
CISCO_DHCP_IP=192.168.0.1
CISCO_DHCP_PORT=22
CISCO_DHCP_USERNAME=admin
CISCO_DHCP_PASSWORD=
CISCO_DHCP_SSH_KEY_PATH=
CISCO_DHCP_ENABLE_PASSWORD=
CISCO_DHCP_TIMEOUT=10
CISCO_DHCP_CACHE_TTL=300

# -----------------------------------------------------------------------------
# Telegram Bot (для v1.6.0 — уведомления о событиях)
# -----------------------------------------------------------------------------
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# =============================================================================
# Omada Controller (v1.4.9.1)
# =============================================================================
OMADA_ENABLED=True
OMADA_URL=https://192.168.0.222:8043
OMADA_CLIENT_ID=твой_реальный_client_id_из_omada
OMADA_CLIENT_SECRET=твой_реальный_client_secret_из_omada
OMADA_ID=твой_реальный_omadac_id_из_omada
OMADA_VERIFY_SSL=False
OMADA_TIMEOUT=15
